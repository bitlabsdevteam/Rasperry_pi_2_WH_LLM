#!/usr/bin/expect -f

set timeout -1

if {$argc < 2} {
    puts stderr "usage: expect_password.exp <password> <command> [args...]"
    exit 2
}

set password [lindex $argv 0]
set cmd [lrange $argv 1 end]

spawn {*}$cmd

expect {
    "*yes/no*" {
        send "yes\r"
        exp_continue
    }
    "*password:*" {
        send -- "$password\r"
        exp_continue
    }
    eof
}

catch wait result
set exit_status [lindex $result 3]
exit $exit_status
